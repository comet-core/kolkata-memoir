---
import '../styles/global.css';

const rawPosts = import.meta.glob('./*.mdx', { eager: true });

const getTitle = (slug: string) => {
  const entry = Object.entries(rawPosts).find(([path]) => path.includes(slug));
  if (!entry) return "[ADD TITLE]";
  const mod = entry[1] as any;
  return mod.frontmatter?.title?.split(': ')[1] ?? "[ADD TITLE]";
};
